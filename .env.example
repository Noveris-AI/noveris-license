# App
DEBUG=false

# Database
DATABASE_TYPE=postgresql+psycopg
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=naviam_postgres
DATABASE_PASSWORD=Postgres@!QAZxsw2.
DATABASE_NAME=naviam_postgres

# Redis
REDIS_TYPE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=naviam_redis
REDIS_PASSWORD=Redis@!QAZxsw2.
REDIS_DB=0

# Session
SESSION_COOKIE_NAME=naviam_session
SESSION_MAX_AGE=28800
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=lax

# CORS (comma-separated, use your production domains in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# RSA Keys
RSA_PRIVATE_KEY_PATH=/app/keys/private.pem
RSA_PUBLIC_KEY_PATH=/app/keys/public.pem

# Rate Limiting
VERIFY_RATE_LIMIT=100
VERIFY_RATE_WINDOW=60

# Login Rate Limiting (per IP)
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300

# Offline process rate limit (per operator)
OFFLINE_PROCESS_RATE_LIMIT=30
OFFLINE_PROCESS_RATE_WINDOW=60

# Offline request bundles
OFFLINE_REQUEST_TTL_SECONDS=900

# Suspicious activation detection
SUSPICIOUS_IP_THRESHOLD=2
